DATA_SOURCE=local
# Para ler uma pasta publica do Google Drive sem OAuth, use:
# DATA_SOURCE=googleDrivePublic
# GOOGLE_DRIVE_FOLDER_URL="https://drive.google.com/drive/folders/ID_DA_PASTA"
GOOGLE_DRIVE_FOLDER_URL=https://drive.google.com/drive/folders/1u1bChpn8_BBD1BaINVThaS2o8f86XY2I?usp=drive_link
# Para producao na Vercel usando Google Drive, use:
# DATA_SOURCE=google-drive
# Opcional. Caminho local da pasta onde ficam as planilhas.
# Pode ser uma pasta sincronizada pelo Google Drive para desktop.
# Se vazio, o sistema usa data/spreadsheets.
LOCAL_SPREADSHEETS_PATH=
SUMMARY_PROVIDER=ruleBased
DASHBOARD_REFRESH_SECONDS=60
DATABASE_URL="file:./dev.db"

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
# Pode ser apenas o ID ou a URL da pasta.
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_SHEET_ID=

MICROSOFT_TENANT_ID=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_SITE_ID=
MICROSOFT_DRIVE_ID=

OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
